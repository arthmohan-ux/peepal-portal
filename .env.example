# ─────────────────────────────────────────────
# PEEPAL HIRING PORTAL — Environment Variables
# Copy this file to .env.local for local dev
# Add all these in Vercel Dashboard → Settings → Environment Variables for production
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── Google OAuth (from GCP → Credentials → OAuth Client) ──
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here

# ── Where OAuth redirects back to ──
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ── Session secret — generate with: openssl rand -base64 32 ──
SESSION_SECRET=generate_a_random_32_char_string_here

# ── Google Service Account (from the JSON key file you downloaded) ──
# Copy the values exactly from your service account JSON file
GOOGLE_SERVICE_ACCOUNT_EMAIL=peepal-portal-server@peepal-hiring-portal.iam.gserviceaccount.com
# The private key — paste the entire key including -----BEGIN/END----- lines
# In Vercel, paste as-is. Locally, keep it on one line with \n for newlines
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# ── Google Sheet ID ──
# Get from the sheet URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
SHEET_ID=your_google_sheet_id_here

# ── Sheet tab names (must match exactly) ──
MASTER_SHEET_NAME=Master Tracker

# ── Transactional email sender (Resend) ──
# Create an API key in Resend and use a verified sending address/domain
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=arth.mohan@peepalconsulting.com

# Backward-compatible fallback sender for local setups that still reference it
GMAIL_SENDER=arth.mohan@peepalconsulting.com

# ── Org domain restriction ──
ALLOWED_DOMAIN=peepalconsulting.com
